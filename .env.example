# Variáveis públicas do frontend (commitadas no .env, safe)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-key>
VITE_SUPABASE_PROJECT_ID=<project-ref>

# ----------------------------------------------------------------------
# Variáveis SECRETAS — NÃO commitar. Use .env.local (já no .gitignore)
# ----------------------------------------------------------------------

# Service role do Supabase. Usada apenas pelo script de seed.
# Pegar em: https://supabase.com/dashboard/project/<project-ref>/settings/api
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------
# Configurada APENAS nos secrets do Supabase (não no Mac).
# Comando: bunx supabase secrets set GEMINI_API_KEY=<chave>
# Pegar em: https://aistudio.google.com/app/apikey
# ----------------------------------------------------------------------
# GEMINI_API_KEY=

# ----------------------------------------------------------------------
# QA contínuo via Browserless (tests/browserless/)
# Pegar token em: https://account.browserless.io
# ----------------------------------------------------------------------
BROWSERLESS_TOKEN=
APP_BASE_URL=https://homeofficelife.com.br
# Max de tentativas por rodada antes de documentar bloqueio
QA_MAX_RETRIES=3
# Auto-fix: gera plano de correção em auto-fix-report.json (não aplica código sozinho)
QA_AUTO_FIX_ENABLED=true
# Se true, só aplica fixes com auto_fix_allowed=true E risk_level=low
QA_ALLOW_SAFE_FIXES_ONLY=true
# Modo de run quando rodado direto (pode ser sobrescrito por --mode=X)
QA_RUN_MODE=smoke
# Opcional — usar só se o fluxo de análise exigir login no futuro
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
# CRON_SECRET pra reference-setups-regression chamar qa-touchpoints-run
CRON_SECRET=

# ----------------------------------------------------------------------
# Afiliação via redes (Awin BR + Lomadee) — preencher após aprovação.
# Configure no .env.local pra dev local e nos env vars do Render pra prod.
# IDs por loja são definidos em src/lib/affiliate.ts (AFFILIATE_NETWORK_BY_STORE).
# ----------------------------------------------------------------------
# Awin BR — cadastro: https://www.awin.com/br/cadastro-de-publicacao
# Cobre: Tok&Stok, MadeiraMadeira, Westwing, Leroy Merlin, Camicado, Carrefour, Casas Bahia, Ponto, Extra
VITE_AWIN_PUBLISHER_ID=
# Lomadee / SocialSoul — cadastro: https://lomadee.com/cadastro
# Cobre: Kabum, Pichau, Etna, Mobly, Kalunga, Terabyte, Americanas
VITE_LOMADEE_SOURCE_ID=
# Admitad — https://www.admitad.com/br
VITE_ADMITAD_PUBLISHER_ID=
# Rakuten Advertising — https://rakutenadvertising.com
VITE_RAKUTEN_SITE_ID=
# Impact — https://impact.com
VITE_IMPACT_ACCOUNT_SID=

# Programas diretos (preencher após cadastro):
# - Amazon Associates BR: https://afiliados.amazon.com.br
VITE_AMAZON_ASSOCIATE_TAG=deskly02-20
# - Mercado Livre Afiliados: https://www.mercadolivre.com.br/afiliados
VITE_MERCADOLIVRE_AFFILIATE_ID=belloliandriw
# - Magazine Você (canal): https://www.magazinevoce.com.br/divulgador
VITE_MAGALU_AFFILIATE_ID=magazinedesklylife
# - Shopee Afiliados: https://affiliate.shopee.com.br
VITE_SHOPEE_AFFILIATE_ID=
# - AliExpress Portals: https://portals.aliexpress.com
VITE_ALIEXPRESS_TRACKING_ID=

# Programas próprios de fabricante (se houver):
VITE_KABUM_AFFILIATE_ID=
VITE_MADEIRAMADEIRA_AFFILIATE_ID=
VITE_MOBLY_AFFILIATE_ID=
